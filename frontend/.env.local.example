# Supabase (server-side only - never NEXT_PUBLIC for service role)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Admin key - server routes only
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=sb_publishable_xxx

# Public site URL used in auth redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JWT (for admin tokens)
JWT_SECRET=<generate: openssl rand -base64 32>

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=512
BEDROCK_TEMPERATURE=0.2

# Admin credentials (password stored as bcrypt hash)
ADMIN_EMAIL=admin@example.com
# Password is managed by Supabase Auth reset/login flow.
