# Path of Function Backend - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
PORT=8000

# ============================================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================================
# Get this from your Supabase project settings > Database > Connection String
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.fcnvhyecdnpsmttayhyq.supabase.co:5432/postgres

# Supabase API (for direct client access if needed)
SUPABASE_URL=https://fcnvhyecdnpsmttayhyq.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================================================
# SECURITY (REQUIRED - Generate new values!)
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_STRING_FROM_COMMAND_ABOVE

# Admin credentials for initial login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_secure_password

# ============================================================================
# CORS (Add your Vercel domain when deployed)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,https://fcnvhyecdnpsmttayhyq.supabase.co

# ============================================================================
# RESEARCH SETTINGS
# ============================================================================
SESSION_TIMEOUT_DAYS=7
ALLOW_SESSION_RESUME=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_TO_FILE=false

# ============================================================================
# OPTIONAL: External Services (Phase 2/3)
# ============================================================================
# Google Cloud / Vertex AI (for RAG chatbot)
# Get your project ID from Google Cloud Console > Select Project
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id  # Alias
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash

# For local development: Set GOOGLE_APPLICATION_CREDENTIALS to your service account JSON
# export GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# Email notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@your-domain.com
